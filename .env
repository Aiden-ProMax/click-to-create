# ============================================================================
# Local Development Environment Configuration
# ============================================================================
#
# This file is needed for local development.
# It is in .gitignore and should NEVER be committed to Git.
# Each developer maintains their own local copy with their own API keys.
#
# Quick start:
# 1. Get Gemini API key from: https://ai.google.dev/ (free)
# 2. Replace the placeholder below with your actual key
# 3. Run: python manage.py migrate
# 4. Run: python manage.py runserver
# 5. Visit: http://localhost:8000
#
# ============================================================================

# === ENVIRONMENT IDENTIFICATION (Required) ===
ENVIRONMENT=development

# === DJANGO CONFIGURATION (Development) ===
DJANGO_SECRET_KEY=dev-insecure-change-me-for-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1:8000,localhost:8000
DJANGO_TIME_ZONE=UTC

# === GOOGLE GENERATIVE AI - REQUIRED ===
# Get FREE API key: https://ai.google.dev/
# Steps:
#   1. Go to https://ai.google.dev/
#   2. Click "Get API Key" 
#   3. Select a project or create a new one
#   4. Copy the API key
#   5. Paste it below (DO NOT commit this!)
GOOGLE_GENERATIVE_AI_KEY=your-free-gemini-api-key-from-ai.google.dev
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash

# === GOOGLE OAUTH - OPTIONAL (Calendar Integration Only) ===
# Only needed if testing Google Calendar sync
OAUTHLIB_INSECURE_TRANSPORT=true
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_OAUTH_CLIENT_JSON_PATH=./webclient.json
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.events
