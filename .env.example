# Local development environment template
# Copy to .env and fill in actual values
# .env file is ignored by Git and should NEVER be committed
#
# Usage: cp .env.example .env
#        Edit .env with your local API keys
#        python manage.py runserver

# === Environment identification ===
ENVIRONMENT=development

# === Django Configuration ===
DJANGO_SECRET_KEY=dev-secret-key-any-value-ok-for-local
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# === Google Generative AI (Gemini) ===
# Get free API key from: https://ai.google.dev/
GOOGLE_GENERATIVE_AI_KEY=your-gemini-api-key-here

# === OAuth2 Configuration ===
# For local development, we allow HTTP
OAUTHLIB_INSECURE_TRANSPORT=true
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_OAUTH_CLIENT_JSON_PATH=./webclient.json

# === Calendar Sync ===
# CalDAV and Google Calendar APIs
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.events
