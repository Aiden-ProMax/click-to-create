# 部署变量示例 - 复制为 deploy_vars.env 并填入真实值

# GCP 项目配置
PROJECT_ID=your-gcp-project-id
REGION=us-central1
APP_NAME=autoplanner
ENVIRON_TAG=prod

# Django 配置
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ALLOWED_HOSTS=your-cloud-run-domain.run.app
DJANGO_DEBUG=false

# 数据库配置 (Cloud SQL)
DB_NAME=autoplanner
DB_USER=autoplanner_user
DB_PASSWORD=your-secure-password-here
DB_INSTANCE=autoplanner-db-prod
CLOUD_SQL_CONNECTION_NAME=your-project-id:us-central1:autoplanner-db-prod

# AI/API 密钥
GEMINI_API_KEY=your-gemini-api-key-here

# Cloud Run URL
CLOUD_RUN_URL=https://your-cloud-run-domain.run.app

# OAuth 配置 (Google)
# 从 Google Cloud Console 的 OAuth 2.0 凭证获取
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret-here
