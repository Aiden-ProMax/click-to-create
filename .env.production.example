# ============================================
# Google Cloud Run Production Environment
# ============================================
# IMPORTANT: Replace all placeholder values with actual values
# Never commit the real .env file to version control

# Django Settings
ENVIRONMENT=production
DJANGO_SECRET_KEY=<your-secure-random-secret-key-here>
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=<your-cloud-run-url.a.run.app>,<your-custom-domain.com>
DJANGO_TIME_ZONE=America/Los_Angeles

# Cloud SQL Database
DB_NAME=autoplanner
DB_USER=postgres
DB_PASSWORD=<your-cloud-sql-password>
CLOUD_SQL_CONNECTION_NAME=<project-id>:<region>:<db-instance-name>

# Google Cloud Project
GCP_PROJECT_ID=<your-gcp-project-id>

# Static Files (Cloud Storage)
GCS_BUCKET_NAME=<your-project>-autoplanner-static

# Google Generative AI (Gemini API)
GOOGLE_GENERATIVE_AI_KEY=<your-gemini-api-key-from-secrets-manager>
GOOGLE_GENERATIVE_AI_MODEL=gemini-1.5-flash

# Google OAuth (Calendar Integration)
# Keep webclient.json in Cloud Secret Manager, reference it instead
GOOGLE_OAUTH_CLIENT_JSON_PATH=/secrets/google-oauth/webclient.json
GOOGLE_OAUTH_REDIRECT_URI=https://<your-cloud-run-url>/oauth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.events

# Logging
LOG_LEVEL=INFO

# Security: NEVER set OAUTHLIB_INSECURE_TRANSPORT in production
# Remove it entirely or set to false
